{
  "compilerOptions": {
    "target": "es2022",
    "module": "esnext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "noEmit": true,
    "lib": ["es2022", "dom", "dom.iterable"],
    "skipLibCheck": true,
    "types": ["@playwright/test", "node"]
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.tsx",
    "playwright.config.ts",
    "vite.config.ts"
  ],
  "references": [
    {
      "path": "../react"
    }
  ]
}
