{
  "compilerOptions": {
    "target": "es2022",
    "module": "esnext",
    "moduleResolution": "bundler",
    "strict": true,
    "noEmit": true,
    "lib": ["es2022", "dom", "dom.iterable"],
    "skipLibCheck": true
  },
  "include": [
    ".storybook/**/*.ts",
    "src/**/*.ts",
    "src/**/*.mdx"
  ]
}
